DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=change-this-to-a-long-random-string
FRONTEND_URL=http://localhost:3000
PORT=4000

# Hook these up when you add the providers (not included in this starter code):
# SMS_PROVIDER_API_KEY=        (e.g. MSG91, Twilio - for OTP phone verification)
# AGE_VERIFICATION_API_KEY=    (e.g. DigiLocker, Signzy, HyperVerge - for govt-ID age check)
# IMAGE_MODERATION_API_KEY=    (e.g. AWS Rekognition, Hive, Microsoft PhotoDNA - for photo screening)
